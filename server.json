{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "com.adbutler/mcp-server",
  "title": "AdButler",
  "description": "Manage AdButler campaigns, zones, ad items, VAST, and reports from Claude, ChatGPT, and Cursor.",
  "repository": {
    "url": "https://github.com/adbutler/mcp-server",
    "source": "github"
  },
  "version": "2.4.2",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@adbutler/mcp-server",
      "version": "2.4.2",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "ADBUTLER_API_KEY",
          "description": "Your AdButler API key. Get it from AdButler Dashboard → Settings → API Keys.",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        }
      ]
    }
  ],
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://mcp.adbutler.com/mcp"
    },
    {
      "type": "sse",
      "url": "https://mcp.adbutler.com/sse"
    }
  ]
}
