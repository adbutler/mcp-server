{
  "name": "@adbutler/mcp-server",
  "version": "2.3.0",
  "mcpName": "com.adbutler/mcp-server",
  "description": "MCP server for the AdButler ad management API. Manage advertisers, campaigns, zones, creatives, placements, VAST video, programmatic, targeting, drafts, contracts, and reports from Claude, ChatGPT, Cursor, Windsurf, and any other MCP client.",
  "type": "module",
  "bin": {
    "adbutler-mcp-server": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:sse": "node dist/sse.js",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "adbutler",
    "advertising",
    "ad-server",
    "ad-management",
    "adtech",
    "advertising-api",
    "vast",
    "programmatic",
    "rtb",
    "openrtb",
    "claude",
    "anthropic",
    "openai",
    "chatgpt",
    "cursor",
    "windsurf",
    "ai-tools",
    "ai-agent"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/adbutler/mcp-server"
  },
  "homepage": "https://github.com/adbutler/mcp-server#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
